{
  "name": "@portatlas/api-client",
  "version": "0.0.0",
  "private": true,
  "description": "Private schema-checked client for the PortAtlas working-title local API.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "corepack pnpm run format:check && corepack pnpm run check:generated && corepack pnpm run lint && corepack pnpm run typecheck && corepack pnpm run test && corepack pnpm run build",
    "check:generated": "node ./scripts/generate-openapi-types.mjs --check",
    "contracts:check": "corepack pnpm run check:generated",
    "format": "prettier --ignore-path ../../.prettierignore --write .",
    "format:check": "prettier --ignore-path ../../.prettierignore --check .",
    "generate": "node ./scripts/generate-openapi-types.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false"
  },
  "devDependencies": {
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.18.0"
  }
}
